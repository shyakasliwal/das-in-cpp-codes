class Solution {
  public:
    long subarrayXor(vector<int> &arr, int k) {
        // code here
        int n = arr.size();
        long count =0;
        for(int i=0;i<n-1;i++){
            int sum =0;
            for(int j=i; j<n;j++){
               sum=sum^arr[j];
               if(sum==k){
                   count++;
               }
            }    
        }
        return count;
    }
};
